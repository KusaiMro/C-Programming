//using while loop
#include<stdio.h>

int main()
{
    int i=1,j;
    while(i<=4)
    {
        j=1;
        while(j<=i)
        {
            printf("%d",j);
             j++;
        }
        printf("\n");
        i++;
    }
    
    return 0;
}
