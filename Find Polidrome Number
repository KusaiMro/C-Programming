#include <stdio.h>

int main() {
    int n,digit,reverse=0;
    
    printf("Enter any number:");
    scanf("%d",&n);
    int original=n;
    
    while(n>0){
        digit= n%10;
        reverse= reverse * 10 + digit;
        n = n/10;
    }
    if(reverse==original){
        printf("%d is a Polidrome number.",original);
    }else{
        printf("%d is not Polidrome number.",original);
    }

    return 0;
}
