#include <stdio.h>

int main() 
{
  int n,i,prime=0;
  printf("Enter any number:");
  scanf("%d",&n);
  
  if(n<=1)
  {
      printf("%d is not prime number.",n);
  }else
  {
     for(i=2;i<n;i++){
        if(n % i==0)
        {
            prime=1;
            break;
        }
     }
     if(prime==0){
         printf("%d is the prime number.",n);
     }else{
         printf("%d is not the prime number.",n);
     }
  }

    return 0;
}
